<mujoco model="g1_pick_and_place">
  <!--
    VLA Pick-and-Place Scene
    Robot: Unitree G1 29-DoF (MuJoCo Menagerie)
    Task:  Pick object from Table A → Place on Table B
    
    Table A (source): robot's front-right, 3 objects
    Table B (target): robot's front-left, empty
  -->

  <compiler meshdir="../../mujoco_menagerie/unitree_g1/assets" angle="radian"/>
  <include file="../../mujoco_menagerie/unitree_g1/g1.xml"/>

  <!-- Override integrator for stable object contacts -->
  <option integrator="Euler" timestep="0.002"/>

  <statistic center="0.3 0 0.8" extent="1.5"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.15 0.15 0.15" specular="0.5 0.5 0.5"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="150" elevation="-25"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="table_a_mat" rgba="0.82 0.71 0.55 1"/>
    <material name="table_b_mat" rgba="0.55 0.65 0.75 1"/>
    <material name="red_obj" rgba="0.85 0.15 0.15 1"/>
    <material name="blue_obj" rgba="0.15 0.15 0.85 1"/>
    <material name="green_obj" rgba="0.15 0.75 0.15 1"/>
  </asset>

  <worldbody>
    <!-- Ground -->
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Lighting -->
    <light pos="0.6 0 2.5" dir="0 0 -1" diffuse="0.5 0.5 0.5" specular="0.2 0.2 0.2" directional="true"/>
    <light pos="1 -1 2" dir="-0.5 0.5 -1" diffuse="0.3 0.3 0.3"/>

    <!-- ===== TABLE A (SOURCE) — right side, has objects ===== -->
    <!-- Table surface at z = 0.40 + 0.02 half-height = z=0.42 surface -->
    <geom name="table_a_top" type="box" pos="0.55 -0.25 0.40" size="0.25 0.20 0.02"
          material="table_a_mat" friction="0.8 0.005 0.0001"/>
    <geom name="table_a_leg1" type="cylinder" pos="0.77  -0.07 0.19" size="0.02 0.19" material="table_a_mat"/>
    <geom name="table_a_leg2" type="cylinder" pos="0.33  -0.07 0.19" size="0.02 0.19" material="table_a_mat"/>
    <geom name="table_a_leg3" type="cylinder" pos="0.77  -0.43 0.19" size="0.02 0.19" material="table_a_mat"/>
    <geom name="table_a_leg4" type="cylinder" pos="0.33  -0.43 0.19" size="0.02 0.19" material="table_a_mat"/>

    <!-- ===== TABLE B (TARGET) — left side, empty ===== -->
    <geom name="table_b_top" type="box" pos="0.55 0.25 0.40" size="0.25 0.20 0.02"
          material="table_b_mat" friction="0.8 0.005 0.0001"/>
    <geom name="table_b_leg1" type="cylinder" pos="0.77  0.07 0.19" size="0.02 0.19" material="table_b_mat"/>
    <geom name="table_b_leg2" type="cylinder" pos="0.33  0.07 0.19" size="0.02 0.19" material="table_b_mat"/>
    <geom name="table_b_leg3" type="cylinder" pos="0.77  0.43 0.19" size="0.02 0.19" material="table_b_mat"/>
    <geom name="table_b_leg4" type="cylinder" pos="0.33  0.43 0.19" size="0.02 0.19" material="table_b_mat"/>

    <!-- ===== 3 OBJECTS ON TABLE A ===== -->
    <!-- All start on table A surface (z=0.42) + object half-height + 1cm gap -->

    <!-- Red Mug (cylinder) -->
    <body name="obj_red_mug" pos="0.50 -0.25 0.50">
      <freejoint name="mug_joint"/>
      <geom name="mug_body" type="cylinder" size="0.035 0.05"
            material="red_obj" condim="4" friction="0.8 0.005 0.0001" mass="0.3"/>
    </body>

    <!-- Blue Cube -->
    <body name="obj_blue_cube" pos="0.60 -0.30 0.47">
      <freejoint name="cube_joint"/>
      <geom name="cube_geom" type="box" size="0.03 0.03 0.03"
            material="blue_obj" condim="4" friction="0.6 0.005 0.0001" mass="0.15"/>
    </body>

    <!-- Green Bottle (capsule) -->
    <body name="obj_green_bottle" pos="0.55 -0.18 0.53">
      <freejoint name="bottle_joint"/>
      <geom name="bottle_geom" type="capsule" size="0.025 0.07"
            material="green_obj" condim="4" friction="0.5 0.005 0.0001" mass="0.25"/>
    </body>

    <!-- ===== CAMERAS ===== -->
    <!-- head_cam already defined in g1.xml (attached to torso_link) -->
    <!-- Overview camera for external viz / video -->
    <camera name="overview_cam" pos="1.8 -1.0 1.8" xyaxes="0.65 0.75 0 -0.35 0.3 0.87" fovy="55"/>
    <!-- Front view -->
    <camera name="front_cam" pos="1.5 0 1.0" xyaxes="0 -1 0 0 0 1" fovy="50"/>
  </worldbody>

</mujoco>
