<mujoco model="tabletop_scene">
    <compiler angle="radian"/>
    <option timestep="0.005" gravity="0 0 -9.81"/>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512"/>
        <texture name="texplane" type="2d" builtin="checker" rgb1="0.2 0.3 0.4" rgb2="0.1 0.15 0.2" width="512" height="512" mark="cross" markrgb="0.8 0.8 0.8"/>
        <material name="matplane" reflectance="0.3" texture="texplane" texrepeat="1 1" texuniform="true"/>
        <material name="mattable" rgba="0.8 0.6 0.4 1"/>
        <material name="matred" rgba="0.8 0.1 0.1 1"/>
        <material name="matblue" rgba="0.1 0.1 0.8 1"/>
        <material name="matgreen" rgba="0.1 0.8 0.1 1"/>
        <material name="matyellow" rgba="0.8 0.8 0.1 1"/>
    </asset>

    <worldbody>
        <light directional="true" diffuse="0.8 0.8 0.8" specular="0.2 0.2 0.2" pos="0 0 5" dir="0 0 -1"/>
        <light directional="true" diffuse="0.3 0.3 0.3" pos="2 2 4" dir="-1 -1 -1"/>
        <geom name="floor" type="plane" size="0 0 1" pos="0 0 0" material="matplane"/>

        <!-- Table -->
        <body name="table" pos="0.5 0 0.75">
            <geom name="table_top" type="box" size="0.4 0.3 0.02" material="mattable"/>
            <geom name="table_leg1" type="box" size="0.02 0.02 0.375" pos="0.35 0.25 -0.375" material="mattable"/>
            <geom name="table_leg2" type="box" size="0.02 0.02 0.375" pos="-0.35 0.25 -0.375" material="mattable"/>
            <geom name="table_leg3" type="box" size="0.02 0.02 0.375" pos="0.35 -0.25 -0.375" material="mattable"/>
            <geom name="table_leg4" type="box" size="0.02 0.02 0.375" pos="-0.35 -0.25 -0.375" material="mattable"/>
        </body>
            
        <!-- Red Cylinder (Mug approximation) -->
        <body name="obj_red_mug" pos="0.6 0.1 0.82">
            <freejoint/>
            <geom name="geom_red_mug" type="cylinder" size="0.04 0.05" material="matred" mass="0.3" friction="0.5 0.005 0.0001"/>
        </body>

        <!-- Blue Box (Block approximation) -->
        <body name="obj_blue_box" pos="0.4 0.0 0.79">
            <freejoint/>
            <geom name="geom_blue_box" type="box" size="0.04 0.04 0.04" material="matblue" mass="0.2" friction="0.4 0.005 0.0001"/>
        </body>

        <!-- Green Capsule (Bottle approximation) -->
        <body name="obj_green_bottle" pos="0.5 -0.15 0.83">
            <freejoint/>
            <geom name="geom_green_bottle" type="capsule" size="0.03 0.08" material="matgreen" mass="0.4" friction="0.3 0.005 0.0001"/>
        </body>

        <!-- Yellow Sphere (Ball approximation) -->
        <body name="obj_yellow_ball" pos="0.65 -0.1 0.78">
            <freejoint/>
            <geom name="geom_yellow_ball" type="sphere" size="0.03" material="matyellow" mass="0.1" friction="0.2 0.005 0.0001"/>
        </body>

        <!-- Cameras for Active Perception testing -->
        <camera name="overview_cam" pos="-0.5 0 1.5" xyaxes="0 -1 0 0.8 0 0.6" fovy="45"/>
        <camera name="wrist_cam_proxy" pos="0.3 0 1.2" xyaxes="0 -1 0 0.5 0 0.866" fovy="60"/>
    </worldbody>
</mujoco>
