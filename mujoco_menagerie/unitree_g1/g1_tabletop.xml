<mujoco model="g1_tabletop_scene">
  <include file="g1.xml"/>

  <!-- Override G1's implicitfast integrator — it breaks contact for non-robot geoms -->
  <option integrator="Euler" timestep="0.002"/>

  <statistic center="0.3 0 0.8" extent="1.2"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.15 0.15 0.15" specular="0.5 0.5 0.5"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="140" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="table_mat" rgba="0.82 0.71 0.55 1"/>
    <material name="red_obj" rgba="0.85 0.15 0.15 1"/>
    <material name="blue_obj" rgba="0.15 0.15 0.85 1"/>
    <material name="green_obj" rgba="0.15 0.75 0.15 1"/>
    <material name="yellow_obj" rgba="0.9 0.9 0.1 1"/>
  </asset>

  <worldbody>
    <!-- Ground -->
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <light pos="0.6 0 2.5" dir="0 0 -1" diffuse="0.5 0.5 0.5" specular="0.2 0.2 0.2" directional="true"/>
    <light pos="1 -1 2" dir="-0.5 0.5 -1" diffuse="0.3 0.3 0.3"/>

    <!-- TABLE: direct worldbody geoms (solid, no body wrapper) -->
    <!-- Table surface at z=0.44 (pos 0.40 + half-size 0.04) -->
    <geom name="table_top" type="box" pos="0.65 0 0.40" size="0.30 0.40 0.04"
          material="table_mat" friction="0.8 0.005 0.0001"/>
    <geom name="leg1" type="cylinder" pos="0.92 0.37 0.18" size="0.025 0.18" material="table_mat"/>
    <geom name="leg2" type="cylinder" pos="0.38 0.37 0.18" size="0.025 0.18" material="table_mat"/>
    <geom name="leg3" type="cylinder" pos="0.92 -0.37 0.18" size="0.025 0.18" material="table_mat"/>
    <geom name="leg4" type="cylinder" pos="0.38 -0.37 0.18" size="0.025 0.18" material="table_mat"/>

    <!-- OBJECTS: spawn at table surface (0.44) + half-height + 1cm gap -->
    <body name="obj_red_mug" pos="0.60 0.08 0.55">
      <freejoint name="mug_joint"/>
      <geom name="mug_body" type="cylinder" size="0.035 0.05"
            material="red_obj" condim="4" friction="0.8 0.005 0.0001" mass="0.3"/>
    </body>

    <body name="obj_blue_box" pos="0.72 -0.08 0.52">
      <freejoint name="box_joint"/>
      <geom name="box_geom" type="box" size="0.03 0.03 0.03"
            material="blue_obj" condim="4" friction="0.6 0.005 0.0001" mass="0.15"/>
    </body>

    <body name="obj_green_bottle" pos="0.65 -0.18 0.58">
      <freejoint name="bottle_joint"/>
      <geom name="bottle_geom" type="capsule" size="0.025 0.07"
            material="green_obj" condim="4" friction="0.5 0.005 0.0001" mass="0.25"/>
    </body>

    <body name="obj_yellow_ball" pos="0.58 0.18 0.50">
      <freejoint name="ball_joint"/>
      <geom name="ball_geom" type="sphere" size="0.03"
            material="yellow_obj" condim="4" friction="0.6 0.005 0.0001" mass="0.1"/>
    </body>

    <!-- CAMERAS -->
    <camera name="overview_cam" pos="1.8 -1.2 1.8" xyaxes="0.7 0.7 0 -0.3 0.3 0.9" fovy="50"/>
    <camera name="side_cam" pos="0.6 -1.5 1.0" xyaxes="1 0 0 0 0.3 0.9" fovy="60"/>
  </worldbody>

</mujoco>
